---
import LangToggle from "../components/LangToggle.tsx";
import NavLinks from "../components/NavLinks.tsx";
import MobileNav from "../components/MobileNav.tsx";
import ProgressBar from "../components/ProgressBar.tsx";
import { readFileSync, readdirSync } from "fs";
import { join } from "path";

interface Props {
  title: string;
  activePage: "cards" | "graph" | "notes" | "swipe" | "starred" | "reported";
}

const { title, activePage } = Astro.props;

const cardsDir = join(process.cwd(), "../content/cards");
let cards: any[] = [];
try {
  const files = readdirSync(cardsDir).filter((f: string) => f.endsWith(".json"));
  cards = files.map((f: string) => JSON.parse(readFileSync(join(cardsDir, f), "utf-8")));
} catch {}
---

<style is:global>
  .md-prose p { margin: 0 0 0.5em; }
  .md-prose p:last-child { margin-bottom: 0; }
  .md-prose table { border-collapse: collapse; width: 100%; font-size: 0.8125rem; margin: 0.5em 0; }
  .md-prose th, .md-prose td { border: 1px solid #e8e6dc; padding: 0.35em 0.6em; text-align: left; }
  .md-prose th { background: #eae8e0; font-weight: 600; }
  .md-prose code { background: #eae8e0; padding: 0.1em 0.35em; border-radius: 3px; font-size: 0.85em; font-family: monospace; }
  .md-prose pre { background: #eae8e0; padding: 0.75em 1em; border-radius: 6px; overflow-x: auto; }
  .md-prose pre code { background: none; padding: 0; }
  .md-prose ul, .md-prose ol { padding-left: 1.25em; margin: 0.25em 0; }
  .md-prose li { margin: 0.15em 0; }
</style>

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Doc Distill</title>
  </head>
  <body class="bg-surface text-charcoal min-h-screen flex flex-col pb-16 md:pb-0">
    <nav class="border-b border-surface-border bg-surface-raised">
      <div class="flex items-center gap-4 px-6 py-3 max-w-5xl mx-auto w-full">
        <a href="/" class="text-accent-orange font-bold text-lg hover:opacity-80 transition-opacity shrink-0">Doc Distill</a>
        <NavLinks client:load activePage={activePage} />
        <div class="ml-auto shrink-0">
          <LangToggle client:load />
        </div>
      </div>
    </nav>
    <ProgressBar client:load cards={cards} />
    <main class="flex-1 overflow-hidden">
      <slot />
    </main>
    <MobileNav client:load activePage={activePage} />
  </body>
</html>
