---
import LangToggle from "../components/LangToggle.tsx";
import HomepageDashboard from "../components/HomepageDashboard.tsx";
import { readFileSync, readdirSync } from "fs";
import { join } from "path";

const cardsDir = join(process.cwd(), "../content/cards");
let cardCount = 0;
let topicCount = 0;
const topicSet = new Set<string>();
try {
  const files = readdirSync(cardsDir).filter((f) => f.endsWith(".json"));
  cardCount = files.length;
  for (const f of files) {
    const c = JSON.parse(readFileSync(join(cardsDir, f), "utf-8"));
    for (const tag of c.tags) topicSet.add(tag);
  }
  topicCount = topicSet.size;
} catch {}

let allCards: any[] = [];
try {
  const cardFiles = readdirSync(cardsDir).filter((f) => f.endsWith(".json"));
  allCards = cardFiles.map((f) => JSON.parse(readFileSync(join(cardsDir, f), "utf-8")));
} catch {}

const sources = [
  { name: "Platform Docs", url: "platform.claude.com/docs", count: 90 },
  { name: "Engineering Blog", url: "anthropic.com/engineering", count: 22 },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Doc Distill — 碎片时间，系统学习</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

      :root {
        --cream: #f5f4ed;
        --cream-dark: #e8e6dc;
        --charcoal: #1a1a18;
        --charcoal-light: #30302e;
        --terracotta: #d97757;
        --terracotta-dark: #c46a4c;
        --slate: #6b6b68;
        --slate-light: #9b9b97;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'Inter', -apple-system, sans-serif;
        background: var(--cream);
        color: var(--charcoal);
        -webkit-font-smoothing: antialiased;
      }

      /* Nav */
      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 2.5rem;
        max-width: 1200px;
        margin: 0 auto;
      }
      .nav-logo {
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--charcoal);
        text-decoration: none;
        letter-spacing: -0.02em;
      }
      .nav-logo span { color: var(--terracotta); }
      .nav-right { display: flex; align-items: center; gap: 1.5rem; }
      .nav-link {
        font-size: 0.875rem;
        color: var(--slate);
        text-decoration: none;
        transition: color 0.2s;
      }
      .nav-link:hover { color: var(--charcoal); }

      /* Hero */
      .hero {
        max-width: 1200px;
        margin: 0 auto;
        padding: 6rem 2.5rem 4rem;
        text-align: center;
      }
      .hero-badge {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--terracotta);
        background: rgba(217, 119, 87, 0.1);
        padding: 0.4rem 1rem;
        border-radius: 100px;
        margin-bottom: 2rem;
      }
      .hero h1 {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: -0.03em;
        margin-bottom: 1.5rem;
        color: var(--charcoal);
      }
      .hero h1 em {
        font-style: normal;
        color: var(--terracotta);
      }
      .hero-sub {
        font-size: clamp(1.1rem, 2vw, 1.35rem);
        color: var(--slate);
        max-width: 600px;
        margin: 0 auto 3rem;
        line-height: 1.6;
        font-weight: 300;
      }
      .hero-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.9rem 2rem;
        background: var(--charcoal);
        color: var(--cream);
        border-radius: 100px;
        font-size: 0.95rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
      }
      .hero-cta:hover {
        background: var(--terracotta);
        transform: translateY(-1px);
      }
      .hero-cta-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.9rem 2rem;
        background: transparent;
        color: var(--charcoal);
        border: 1px solid var(--cream-dark);
        border-radius: 100px;
        font-size: 0.95rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
        margin-left: 0.75rem;
      }
      .hero-cta-secondary:hover {
        border-color: var(--charcoal);
      }

      /* Stats */
      .stats {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 2.5rem 4rem;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      }
      .stat {
        text-align: center;
        padding: 2rem;
      }
      .stat-num {
        font-size: 3rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        color: var(--charcoal);
        line-height: 1;
      }
      .stat-label {
        font-size: 0.875rem;
        color: var(--slate);
        margin-top: 0.5rem;
      }

      /* How it works */
      .section {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 2.5rem;
      }
      .section-title {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--terracotta);
        margin-bottom: 1rem;
      }
      .section h2 {
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 3rem;
        line-height: 1.2;
      }

      /* Cards grid */
      .features {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      }
      .feature {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .feature:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0,0,0,0.06);
      }
      .feature-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1.25rem;
      }
      .feature h3 {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        letter-spacing: -0.01em;
      }
      .feature p {
        font-size: 0.875rem;
        color: var(--slate);
        line-height: 1.6;
      }

      /* Sources */
      .sources {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        margin-top: 2rem;
      }
      .source {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .source-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        background: rgba(217, 119, 87, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
      }
      .source h3 {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.25rem;
      }
      .source p {
        font-size: 0.8rem;
        color: var(--slate);
      }
      .source-count {
        font-size: 0.75rem;
        color: var(--terracotta);
        font-weight: 500;
        margin-top: 0.25rem;
      }

      /* Card types preview */
      .types {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 0.75rem;
        margin-top: 2rem;
      }
      .type-pill {
        text-align: center;
        padding: 1rem 0.5rem;
        background: white;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--slate);
        transition: all 0.2s;
      }
      .type-pill:hover { transform: translateY(-2px); }
      .type-emoji { font-size: 1.5rem; display: block; margin-bottom: 0.5rem; }

      /* Pipeline */
      .pipeline {
        display: flex;
        flex-direction: column;
        gap: 0;
      }
      .pipe-step {
        display: flex;
        gap: 1.5rem;
        align-items: flex-start;
      }
      .pipe-num {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: var(--charcoal);
        color: var(--cream);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1rem;
        flex-shrink: 0;
      }
      .pipe-body {
        flex: 1;
        background: white;
        border-radius: 16px;
        padding: 1.5rem 2rem;
      }
      .pipe-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
      }
      .pipe-header h3 {
        font-size: 1.05rem;
        font-weight: 600;
        letter-spacing: -0.01em;
      }
      .pipe-tag {
        font-size: 0.65rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 0.2rem 0.5rem;
        border-radius: 100px;
        background: rgba(217, 119, 87, 0.1);
        color: var(--terracotta);
      }
      .pipe-body p {
        font-size: 0.875rem;
        color: var(--slate);
        line-height: 1.65;
        margin-bottom: 1rem;
      }
      .pipe-io {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      .pipe-in {
        color: var(--slate);
        background: var(--cream);
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
      }
      .pipe-arrow { color: var(--terracotta); font-weight: 700; }
      .pipe-out {
        color: var(--terracotta);
        background: rgba(217, 119, 87, 0.08);
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
        font-weight: 500;
      }
      .pipe-connector {
        width: 2px;
        height: 24px;
        background: var(--cream-dark);
        margin-left: 19px;
      }

      /* Footer CTA */
      .footer-cta {
        text-align: center;
        padding: 5rem 2.5rem;
        max-width: 1200px;
        margin: 0 auto;
      }
      .footer-cta h2 {
        font-size: clamp(1.5rem, 3vw, 2rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
      }
      .footer-cta p {
        color: var(--slate);
        margin-bottom: 2rem;
        font-size: 1rem;
      }

      /* Divider */
      .divider {
        max-width: 1200px;
        margin: 0 auto;
        border: none;
        border-top: 1px solid var(--cream-dark);
      }

      /* Footer */
      .footer {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.8rem;
        color: var(--slate-light);
      }
      .footer a { color: var(--terracotta); text-decoration: none; }
      .footer a:hover { text-decoration: underline; }

      /* Mobile */
      @media (max-width: 768px) {
        .nav { padding: 1rem 1.5rem; }
        .hero { padding: 3rem 1.5rem 2rem; }
        .hero-cta-secondary { margin-left: 0; margin-top: 0.75rem; display: inline-flex; }
        .stats { grid-template-columns: repeat(3, 1fr); padding: 1rem 1.5rem 2rem; gap: 0.5rem; }
        .stat { padding: 1rem; }
        .stat-num { font-size: 2rem; }
        .section { padding: 2rem 1.5rem; }
        .features { grid-template-columns: 1fr; }
        .sources { grid-template-columns: 1fr; }
        .types { grid-template-columns: repeat(3, 1fr); }
        .footer-cta { padding: 3rem 1.5rem; }
        .footer { flex-direction: column; gap: 0.5rem; text-align: center; }
        .pipe-step { gap: 0.75rem; }
        .pipe-num { width: 32px; height: 32px; font-size: 0.85rem; border-radius: 8px; }
        .pipe-body { padding: 1rem 1.25rem; }
        .pipe-connector { margin-left: 15px; }
        .pipe-io { flex-wrap: wrap; }
      }
    </style>
  </head>
  <body>
    <!-- Nav -->
    <nav class="nav">
      <a href="/" class="nav-logo">Doc <span>Distill</span></a>
      <div class="nav-right">
        <a href="/cards" class="nav-link">Cards</a>
        <a href="/graph" class="nav-link">Graph</a>
        <a href="/swipe" class="nav-link">Swipe</a>
        <a href="/starred" class="nav-link">⭐ Starred</a>
        <a href="/reported" class="nav-link">🚩 Reported</a>
        <LangToggle client:load />
      </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-badge">把任何文档蒸馏成知识卡片</div>
      <h1>碎片时间<br /><em>系统学习</em></h1>
      <p class="hero-sub">
        任何技术文档，AI 自动拆解为原子化学习卡片。<br />
        每张 2-5 分钟，中英双语，手机刷卡片建心智模型。
      </p>
      <div>
        <a href="/cards" class="hero-cta">开始学习 →</a>
        <a href="/graph" class="hero-cta-secondary">浏览知识图谱</a>
      </div>
      <HomepageDashboard client:only="preact" cards={allCards} />
    </section>

    <!-- Stats -->
    <div class="stats">
      <div class="stat">
        <div class="stat-num">{cardCount}</div>
        <div class="stat-label">学习卡片</div>
      </div>
      <div class="stat">
        <div class="stat-num">112</div>
        <div class="stat-label">源文档页面</div>
      </div>
      <div class="stat">
        <div class="stat-num">6</div>
        <div class="stat-label">知识表达类型</div>
      </div>
    </div>

    <hr class="divider" />

    <!-- Pipeline -->
    <section class="section">
      <div class="section-title">Distillation Pipeline</div>
      <h2>从原始文档到知识卡片的 5 步蒸馏</h2>

      <div class="pipeline">
        <!-- Step 1 -->
        <div class="pipe-step">
          <div class="pipe-num">1</div>
          <div class="pipe-body">
            <div class="pipe-header">
              <h3>Scrape — 抓取原始内容</h3>
              <span class="pipe-tag">自动化</span>
            </div>
            <p>输入文档站 URL，自动发现所有页面并抓取。对 SPA 站点用 headless browser 渲染。本地缓存 + content hash 比对，只处理新增和变化的页面。</p>
            <div class="pipe-io">
              <span class="pipe-in">IN: URLs</span>
              <span class="pipe-arrow">→</span>
              <span class="pipe-out">OUT: 112 pages HTML</span>
            </div>
          </div>
        </div>

        <div class="pipe-connector"></div>

        <!-- Step 2 -->
        <div class="pipe-step">
          <div class="pipe-num">2</div>
          <div class="pipe-body">
            <div class="pipe-header">
              <h3>Survey — AI 全局扫描分层</h3>
              <span class="pipe-tag">AI</span>
            </div>
            <p>把所有页面标题和摘要一次性交给 AI，做三件事：按重要性分层（L0 核心 / L1 实用 / L2 深入），标记依赖关系（A 需要先懂 B），跳过不值得记忆的内容（changelog、纯 API 参数列表、安装步骤）。</p>
            <div class="pipe-io">
              <span class="pipe-in">IN: 112 页摘要</span>
              <span class="pipe-arrow">→</span>
              <span class="pipe-out">OUT: 79 页保留，33 页跳过</span>
            </div>
          </div>
        </div>

        <div class="pipe-connector"></div>

        <!-- Step 3 -->
        <div class="pipe-step">
          <div class="pipe-num">3</div>
          <div class="pipe-body">
            <div class="pipe-header">
              <h3>Generate — 原子化拆解 + 双语生成</h3>
              <span class="pipe-tag">AI</span>
            </div>
            <p>逐页分析，AI 决定每页拆成几张卡片、每张用哪种知识结构（Fact / Problem→Solution / Concept→Model / How-to / Comparison / Architecture）。同时生成中英双语内容，每张卡片控制在 150 词以内，自包含——不需要上下文就能读懂。</p>
            <div class="pipe-io">
              <span class="pipe-in">IN: 79 页原文</span>
              <span class="pipe-arrow">→</span>
              <span class="pipe-out">OUT: {cardCount} 张双语卡片</span>
            </div>
          </div>
        </div>

        <div class="pipe-connector"></div>

        <!-- Step 4 -->
        <div class="pipe-step">
          <div class="pipe-num">4</div>
          <div class="pipe-body">
            <div class="pipe-header">
              <h3>Dedup — 去重与合并</h3>
              <span class="pipe-tag">自动化</span>
            </div>
            <p>不同源页面可能讲同一件事。通过 content hash 清除完全重复，再用 title/tag 相似度检测语义重叠。旧版卡片（schema 变更后的残留）自动清理。保证每张卡片是一个原子知识点，没有冗余。</p>
            <div class="pipe-io">
              <span class="pipe-in">IN: 150 张原始卡片</span>
              <span class="pipe-arrow">→</span>
              <span class="pipe-out">OUT: {cardCount} 张去重卡片</span>
            </div>
          </div>
        </div>

        <div class="pipe-connector"></div>

        <!-- Step 5 -->
        <div class="pipe-step">
          <div class="pipe-num">5</div>
          <div class="pipe-body">
            <div class="pipe-header">
              <h3>Graph — 构建知识图谱</h3>
              <span class="pipe-tag">自动化</span>
            </div>
            <p>扫描所有卡片的关联声明（requires / extends / related / compares），构建知识图谱。按主题聚类，计算连接强度。图谱驱动手机端的智能推荐——刷完一张卡片，优先推送关联知识点。</p>
            <div class="pipe-io">
              <span class="pipe-in">IN: {cardCount} 张卡片</span>
              <span class="pipe-arrow">→</span>
              <span class="pipe-out">OUT: 知识图谱（185 条关系）</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- Card Types -->
    <section class="section">
      <div class="section-title">6 Knowledge Patterns</div>
      <h2>六种知识表达，适配不同认知需求</h2>
      <div class="types">
        <div class="type-pill">
          <span class="type-emoji">📌</span>
          Fact<br /><span style="color: var(--slate-light);">事实</span>
        </div>
        <div class="type-pill">
          <span class="type-emoji">🔧</span>
          Problem<br />→ Solution
        </div>
        <div class="type-pill">
          <span class="type-emoji">💡</span>
          Concept<br />→ Model
        </div>
        <div class="type-pill">
          <span class="type-emoji">📋</span>
          How-to<br /><span style="color: var(--slate-light);">步骤</span>
        </div>
        <div class="type-pill">
          <span class="type-emoji">⚖️</span>
          Compare<br /><span style="color: var(--slate-light);">对比</span>
        </div>
        <div class="type-pill">
          <span class="type-emoji">🏗️</span>
          Architect<br /><span style="color: var(--slate-light);">架构</span>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- Sources -->
    <section class="section">
      <div class="section-title">Current Collection</div>
      <h2>当前已蒸馏：Claude 开发文档</h2>
      <p style="color: var(--slate); margin-top: -2rem; margin-bottom: 2rem; font-size: 0.9rem;">基于公开发布的文档和博客整理，非官方项目</p>
      <div class="sources">
        <div class="source">
          <div class="source-icon">📖</div>
          <div>
            <h3>Claude Platform Docs</h3>
            <p>platform.claude.com/docs</p>
            <div class="source-count">90 pages → API, Tool Use, Agent SDK, Prompt Engineering...</div>
          </div>
        </div>
        <div class="source">
          <div class="source-icon">🔬</div>
          <div>
            <h3>Anthropic Engineering Blog</h3>
            <p>anthropic.com/engineering</p>
            <div class="source-count">22 posts → Best practices, case studies, design patterns...</div>
          </div>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- Footer CTA -->
    <section class="footer-cta">
      <h2>每天 5 分钟，碎片时间系统学习</h2>
      <p>中英双语 · 手机刷卡 · 进度本地保存 · 完全免费</p>
      <a href="/cards" class="hero-cta">开始学习 →</a>
    </section>

    <!-- Footer -->
    <hr class="divider" />
    <footer class="footer">
      <div>Doc Distill · 非官方项目 · 内容基于 <a href="https://platform.claude.com/docs/en/" target="_blank">公开文档</a> 和 <a href="https://www.anthropic.com/engineering" target="_blank">博客</a> 整理</div>
      <div>{cardCount} cards · {topicCount} topics · 中/EN</div>
    </footer>
  </body>
</html>
